{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(pnpm *)",
      "Bash(node *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(*.pem)",
      "Read(**/*.pem)",
      "Read(*.key)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.crt)",
      "Read(**/*.cer)",
      "Write(.env*)",
      "Write(**/.env*)",
      "Write(secrets/**)",
      "Write(**/secrets/**)",
      "Write(*.pem)",
      "Write(**/*.pem)",
      "Write(*.key)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/*.crt)",
      "Write(**/*.cer)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git branch -D*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git checkout --*)",
      "Bash(git restore *)",
      "Bash(git clean -fd*)",
      "Bash(rm -rf*)",
      "Bash(dd *)",
      "Bash(git commit*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-tool.cjs",
            "timeout": 10,
            "statusMessage": "Harness 安全守护"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-gate.cjs stop",
            "timeout": 300,
            "statusMessage": "运行 harness 质量门禁"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "agent",
            "prompt": "你是强制 AI harness 代码审查子 agent。审查前先运行 `git diff --name-only` 查看本次改动了哪些文件。若任一改动文件匹配 `.claude/**`、`.husky/**`、`scripts/verify-skills.mjs`、`scripts/*.test.mjs`、`skills-lock.json`、`package.json`、`CLAUDE.md`、`docs/ai-harness.md`、`docs/harness-quick-reference.md`、`docs/delivery-template.md`、`docs/review-checklist.md` 或 `docs/verification.md`，就读取 `.claude/agents/harness-reviewer.md` 并严格按其规则审查；否则读取 `.claude/agents/code-reviewer.md` 并严格按其规则审查。不要编辑任何文件。只返回 JSON：{\"ok\":true|false,\"reason\":\"HARNESS_REVIEW_RESULT: PASS|FAIL\\n简短总结。\"}。并提醒用户：Claude 审查不能替代人工最终复核。",
            "timeout": 300,
            "statusMessage": "运行强制代码审查"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify.cjs subagent-stop",
            "timeout": 20,
            "statusMessage": "发送审查完成通知"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify.cjs notification",
            "timeout": 20,
            "statusMessage": "发送系统通知"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "disableBypassPermissionsMode": "disable"
}
